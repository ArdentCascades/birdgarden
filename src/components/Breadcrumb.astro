---
/**
 * Breadcrumb.astro — Accessible breadcrumb navigation
 *
 * Renders a <nav aria-label="Breadcrumb"> with <ol> structure.
 * The last item gets aria-current="page".
 */

interface BreadcrumbItem {
  label: string;
  href?: string; // Omit for the current page (last item)
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="breadcrumb-nav">
  <ol class="breadcrumb-list" role="list">
    {items.map((item, i) => {
      const isLast = i === items.length - 1;
      return (
        <li class="breadcrumb-item" aria-current={isLast ? 'page' : undefined}>
          {!isLast && item.href ? (
            <a href={item.href}>{item.label}</a>
          ) : (
            <span>{item.label}</span>
          )}
          {!isLast && (
            <span class="breadcrumb-separator" aria-hidden="true">›</span>
          )}
        </li>
      );
    })}
  </ol>
</nav>
