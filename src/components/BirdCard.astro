---
/**
 * BirdCard.astro — Bird summary card with season indicator
 *
 * Displays: image, common name, scientific name (de-emphasized),
 * presence badge, season indicator strip.
 */
import SeasonIndicator from './SeasonIndicator.astro';
import Picture from './Picture.astro';

interface MonthPresence {
  month: number;
  presence: 'resident' | 'breeding' | 'wintering' | 'migrating' | null;
}

interface Props {
  slug: string;
  commonName: string;
  scientificName: string;
  presence?: 'resident' | 'breeding' | 'wintering' | 'migrating';
  attractionType?: string | null;
  monthlyPresence?: MonthPresence[];
  imageAlt?: string;
  hasImage?: boolean;
  /** Animation delay for staggered card appearance (ms) */
  animationDelay?: number;
}

const {
  slug,
  commonName,
  scientificName,
  presence,
  attractionType,
  monthlyPresence = [],
  imageAlt = `${commonName} photograph`,
  hasImage = false,
  animationDelay = 0,
} = Astro.props;

const presenceLabels: Record<string, string> = {
  resident: 'Year-round',
  breeding: 'Breeding',
  wintering: 'Winter visitor',
  migrating: 'Migrating',
};
---

<a
  href={`/birds/${slug}`}
  class="bird-card animate-card-appear"
  style={animationDelay ? `animation-delay: ${animationDelay}ms` : undefined}
>
  <div class="bird-card-image">
    {hasImage ? (
      <Picture slug={slug} entityType="bird" alt={imageAlt} />
    ) : (
      <!-- Placeholder when no image is available -->
      <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--color-sage-100);">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
          <path d="M8 36C8 36 16 24 24 20C32 16 40 20 40 28C40 36 32 40 24 40C20 40 12 38 8 36Z"
            fill="var(--color-sage-300)"/>
          <circle cx="30" cy="18" r="4" fill="var(--color-sage-400)"/>
        </svg>
      </div>
    )}
  </div>

  <div class="bird-card-body">
    <h3 class="bird-card-name">{commonName}</h3>
    <p class="bird-card-scientific scientific-name">{scientificName}</p>

    {presence && (
      <span class={`badge presence-${presence}`}>
        {presenceLabels[presence] ?? presence}
      </span>
    )}

    {attractionType && (
      <p style="font-size: var(--text-xs); color: var(--color-text-muted); margin-top: var(--space-1);">
        Attracted by: {attractionType.replace(/_/g, ' ')}
      </p>
    )}
  </div>

  {monthlyPresence.length > 0 && (
    <div class="bird-card-footer">
      <SeasonIndicator months={monthlyPresence} />
    </div>
  )}
</a>
