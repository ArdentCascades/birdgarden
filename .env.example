# Server
HOST=0.0.0.0
PORT=4321

# Domain (used by Caddy for TLS — replace with your actual domain)
DOMAIN=birdgarden.example.com

# Database (relative or absolute path to SQLite file)
DB_PATH=./db/bird-garden.sqlite

# Media directory (where audio and image files live)
MEDIA_PATH=./media

# Logging
LOG_LEVEL=info
